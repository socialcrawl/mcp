{
  "name": "socialcrawl-mcp",
  "version": "1.2.0",
  "description": "MCP server for SocialCrawl — access 21+ social media platforms through one unified API",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "socialcrawl-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "social-media",
    "api",
    "ai-agents",
    "socialcrawl",
    "tiktok",
    "instagram",
    "youtube",
    "twitter",
    "linkedin",
    "reddit",
    "model-context-protocol"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/RidioDevelopment/socialcrawl-mcp"
  },
  "mcpName": "io.github.RidioDevelopment/socialcrawl",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.1.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
